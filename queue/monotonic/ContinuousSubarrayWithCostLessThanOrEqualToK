package queue.monotonic;

import java.util.*;

/*
Problem - Count Subarrays With Cost Less Than or Equal to K (Lc - 3835)

Brute Approach   - Check every subarray and calculate its cost
Brute T.C        - O(n^2)
Brute S.C        - O(1)

Optimal Approach - Sliding Window + Two Monotonic Deques
Optimal T.C      - O(n)
Optimal S.C      - O(n)
*/

public class ContinuousSubarrayWithCostLessThanOrEqualToK {

    public static void main(String[] args) {

        int[] nums = {1, 3, 2};

        long k = 4;

        // System.out.println("Brute: " + countSubarraysBrute(nums, k));
        System.out.println("Optimal: " + countSubarrays(nums, k));
    }

    public static long countSubarraysBrute(int[] nums, long k) {

        int n = nums.length;

        long count = 0;

        for (int i = 0; i < n; i++) {

            int min = nums[i];
            int max = nums[i];

            for (int j = i; j < n; j++) {

                min = Math.min(min, nums[j]);
                max = Math.max(max, nums[j]);

                long cost = (long) (max - min) * (j - i + 1);

                if (cost <= k) {
                    count++;
                }
            }
        }

        return count;
    }

    public static long countSubarrays(int[] nums, long k) {

        Deque<Integer> maxDeque = new LinkedList<>();
        Deque<Integer> minDeque = new LinkedList<>();

        int left = 0;
        long count = 0;

        for (int right = 0; right < nums.length; right++) {

            // Maintain decreasing deque for maximum
            while (!maxDeque.isEmpty() && nums[maxDeque.peekLast()] <= nums[right]) {

                maxDeque.pollLast();
            }

            // Maintain increasing deque for minimum
            while (!minDeque.isEmpty() && nums[minDeque.peekLast()] >= nums[right]) {

                minDeque.pollLast();
            }

            maxDeque.offerLast(right);
            minDeque.offerLast(right);

            // Shrink invalid window
            while ((long) (nums[maxDeque.peekFirst()] - nums[minDeque.peekFirst()]) * (right - left + 1) > k) {

                if (maxDeque.peekFirst() == left) {
                    maxDeque.pollFirst();
                }

                if (minDeque.peekFirst() == left) {
                    minDeque.pollFirst();
                }

                left++;
            }

            count += (right - left + 1);
        }

        return count;
    }
}